generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId String @id

  // Configuration and state
  birthday UserBirthday?  @relation("UserBirthday")
  leveling UserLeveling[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBirthday {
  userId String @id
  User   User   @relation("UserBirthday", fields: [userId], references: [userId], onDelete: Cascade)

  // Configuration
  date                      DateTime
  timezone                  String?
  showAge                   Boolean  @default(false)
  announceInGuildsByDefault Boolean  @default(false)
  announceInGuildIds        String[] @default([])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guild {
  guildId String @id

  // Configuration
  counting          GuildCounting?     @relation("GuildCounting")
  birthday          GuildBirthday?     @relation("GuildBirthday")
  leveling          GuildLeveling?     @relation("GuildLeveling")
  reactionRoleMenus ReactionRoleMenu[]
  userLeveling      UserLeveling[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuildBirthday {
  guildId String @id
  guild   Guild  @relation("GuildBirthday", fields: [guildId], references: [guildId], onDelete: Cascade)

  // Configuration
  enabled   Boolean @default(false)
  channelId String?
  roleId    String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@unique([guildId, channelId])
}

model GuildCounting {
  guildId String @id
  Guild   Guild  @relation("GuildCounting", fields: [guildId], references: [guildId], onDelete: Cascade)

  // Configuration
  resetOnFail Boolean @default(false)
  channelId   String

  // State
  lastNumber          Int       @default(0) @map("currentNumber")
  lastNumberAt        DateTime? @map("currentNumberAt")
  lastNumberMessageId String?   @map("currentNumberMessageId")
  lastNumberByUserId  String?   @map("currentNumberByUserId")

  // History
  highestNumber          Int       @default(0)
  highestNumberAt        DateTime?
  highestNumberByUserId  String?
  highestNumberMessageId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([channelId])
}

model ReactionRoleMenu {
  id String @id @default(cuid())

  // Configuration
  channelId       String
  messageId       String
  enabled         Boolean  @default(true)
  singleChoice    Boolean  @default(false)
  requiredRoleIds String[] @default([])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation
  guildId String
  guild   Guild?         @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  roles   ReactionRole[]

  // Indexes
  @@index([guildId])
}

model ReactionRole {
  id String @id @default(cuid())

  // Configuration
  emoji  String
  roleId String

  // Relation
  menuId   String
  roleMenu ReactionRoleMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([menuId])
}

model GuildLeveling {
  guildId String @id
  guild   Guild  @relation("GuildLeveling", fields: [guildId], references: [guildId], onDelete: Cascade)

  // Configuration
  enabled         Boolean               @default(false)
  channelId       String?
  rewards         GuildLevelingReward[]
  // Filters
  ignoredChannels String[]              @default([]) // if empty, no channels are ignored otherwise only the specified channels are ignored
  enabledChannels String[]              @default([]) // if empty, all channels are enabled otherwise only the specified channels are enabled
  ignoredRoles    String[]              @default([]) // if empty, no roles are ignored otherwise only the specified roles are ignored
  enabledRoles    String[]              @default([]) // if empty, all roles are enabled otherwise only the specified roles are enabled

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([channelId])
}

model GuildLevelingReward {
  id String @id @default(cuid())

  // Configuration
  level  Int
  roleId String

  // Relation
  guildId       String
  guildLeveling GuildLeveling @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([guildId])
}

model UserLeveling {
  // State
  xp Int @default(0)

  // Relation
  userId  String
  user    User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  // Timestamps
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@id([guildId, userId])
}
